{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adapter Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapters"],
  "properties": {
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "artifact_format", "bundle_input", "notes"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "artifact_format": { "type": "string" },
          "bundle_input": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
