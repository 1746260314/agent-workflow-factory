{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "cases"],
  "properties": {
    "version": { "type": "integer" },
    "project": { "type": "string" },
    "project_goal": { "type": "string" },
    "scope": { "type": "string" },
    "workflow_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "goal", "commands", "tests", "notes", "history"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "blocked", "failed", "sync_pending"]
          },
          "goal": { "type": "string" },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "history": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    }
  }
}
