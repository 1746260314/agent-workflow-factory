{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Loop Cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "cases"],
  "properties": {
    "version": { "type": "integer" },
    "project": { "type": "string" },
    "project_goal": { "type": "string" },
    "scope": { "type": "string" },
    "planning_signals": { "type": "object" },
    "loop_policy": {
      "type": "object",
      "properties": {
        "git_pull_before_case": { "type": "boolean" },
        "git_push_after_case": { "type": "boolean" },
        "max_sync_retries": { "type": "integer" }
      }
    },
    "workflow_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "goal", "commands", "tests", "notes", "history"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "blocked", "failed", "sync_pending"]
          },
          "execution_mode": {
            "type": "string",
            "enum": ["commands", "executor"]
          },
          "executor": {
            "type": "object",
            "properties": {
              "adapter": { "type": "string" },
              "enabled": { "type": "boolean" },
              "mode": { "type": "string" },
              "command_template": { "type": "string" },
              "result_source": { "type": "string" }
            }
          },
          "goal": { "type": "string" },
          "owner_skill": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string" }
          },
          "write_scope": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "history": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    }
  }
}
