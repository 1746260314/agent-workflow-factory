{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Loop Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "case_id",
    "status",
    "summary",
    "tests_run",
    "tests_passed",
    "commit_created",
    "commit_message",
    "files_touched",
    "notes"
  ],
  "properties": {
    "case_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed", "skipped"]
    },
    "summary": { "type": "string" },
    "tests_run": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_passed": { "type": "boolean" },
    "commit_created": { "type": "boolean" },
    "commit_message": { "type": "string" },
    "files_touched": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
